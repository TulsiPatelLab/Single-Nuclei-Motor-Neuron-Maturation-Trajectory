#P26 snRNAseq

data_dir <- "P26_snrnaseq_r1"

counts <- Read10X(data.dir = data_dir)
P26.rna.r1 <- CreateSeuratObject(counts = counts, project = "P26.rna.r1")

P26.rna.r1 <- subset(
  x = P26.rna.r1,
  subset = 
    nCount_RNA > 6000)

data_dir <- "P26_snrnaseq_r2"
counts <- Read10X(data.dir = data_dir)
P26_rna_r2 <- CreateSeuratObject(counts = counts, project = "P26_rna_r2")
P26_rna_r2 <- subset(
  x = P26_rna_r2,
  subset = 
    nCount_RNA > 6000)

#integrate r1r2
P26.rna <- merge(x = P26.rna.r1, y = P26_rna_r2)
P26.rna@assays$SCT <- NULL
DefaultAssay(P26.rna) <- 'RNA'

P26.rna <- NormalizeData(P26.rna, assay = "RNA")
P26.rna <- FindVariableFeatures(P26.rna)
P26.rna <- ScaleData(P26.rna)
P26.rna <- RunPCA(P26.rna)
P26.rna <- IntegrateLayers(object = P26.rna, method = CCAIntegration, orig.reduction = "pca", new.reduction = "integrated.cca",
                                   verbose = FALSE)

# now that integration is complete, rejoin layers
P26.rna@assays$RNA <- JoinLayers(P26.rna@assays$RNA)
P26.rna <- FindNeighbors(P26.rna, reduction = "integrated.cca", dims = 1:50)
P26.rna <- FindClusters(P26.rna, resolution = 0.8)
P26.rna <- RunUMAP(P26.rna, dims = 1:50, reduction = "integrated.cca", return.model=TRUE)
DimPlot(P26.rna, reduction = "umap", label = T, group.by = "orig.ident")
DimPlot(P26.rna, reduction = "umap", label = T, group.by = "seurat_clusters")

P26.rna.mn <- subset(P26.rna, idents = c(0,1,4,5,6, 7,8,12,15))
# 0, 1, 4, 5, 6, 7, 8, 12, 15 = MN
# 3, 17 = E
# 16, 19, 20, 25 = CE
# 10 = Pitx2-IN
# 2 = I
# 9, 22, 23 = VMN
# 18, 21 = C
# 11, 13, 14, 24 = CI

P26.rna$celltype <- P26.rna$seurat_clusters
Idents(P26.rna) <- P26.rna$celltype
P26.rna <- RenameIdents(P26.rna, "0" = "MN", "1" = "MN", "4" = "MN", "5" = "MN", "6" = "MN", "7" = "MN", "8" = "MN", "12" = "MN", "15" = "MN", "3" = "E", "17" = "E", "16" = "CE", "19" = "CE", "20" = "CE", "25" = "CE", "10" = "Pitx2-IN", "2" = "I", "9" = "VMN", "22" = "VMN", "23" = "VMN", "18" = "C", "21" = "C", "11" = "CI", "13" = "CI", "14" = "CI", "24" = "CI")
P26.rna$celltype <- Idents(P26.rna)
Idents(P26.rna) <- "seurat_clusters"

P26.rna.mn <- SCTransform(P26.rna.mn, verbose = T) %>% RunPCA(return.model=TRUE) %>% RunUMAP(dims = 1:50, reduction.name = 'umap.rna', reduction.key = 'rnaUMAP_', return.model=TRUE) %>% FindNeighbors(reduction = "pca", dims = 1:50, verbose = T) %>% FindClusters(resolution = 0.8, verbose =T)
