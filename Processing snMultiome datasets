#E15.5
#first get aggregate gene expression per cluster
DefaultAssay(E15.multi.5k.mn.1154) <- 'RNA'
E15.multi.5k.mn.1154 <- NormalizeData(E15.multi.5k.mn.1154, assay = "RNA")
E15.multi.5k.mn.1154 <- ScaleData(E15.multi.5k.mn.1154, assay = "RNA")
FeaturePlot(E15.multi.5k.mn.1154, features = "Foxp1")
E15.mn.avg <- AggregateExpression(E15.multi.5k.mn.1154, assay = "RNA", slot = "data")
E15.mn.avg <- as.data.frame(E15.mn.avg)
fpkms <- E15.mn.avg
keep <- rowSums(fpkms > 0.2) >= 1
E15.mn.avg.sub <- E15.mn.avg[keep,] #only keep genes that are expressed in atleast one cluster
E15.mn.avg.sub <- setDT(E15.mn.avg.sub, keep.rownames = TRUE) %>% dplyr::rename(gene = rn)
DefaultAssay(E15.multi.5k.mn.1154) <- 'RNA'

#then identify top 20 markers of each cluster
table(Idents(E15.multi.5k.mn.1154))
E15MNmarkers <- FindAllMarkers(E15.multi.5k.mn.1154, only.pos = TRUE, min.pct = 0.25, logfc.threshold = 0.25)

# Define the output file name
output_file <- "E15_top_20_markers_per_allcluster_1154cells.txt"

for (x in 0:16) {
  # Filter top 20 markers for the current cluster
  y <- dplyr::filter(E15MNmarkers, cluster == x) %>% head(n = 20)
  
  # Write top 20 markers to the file
  write.table(y, file = output_file, quote = F, sep = "\t", col.names = F, row.names = F, append = TRUE)
}
colnames <- colnames(E15MNmarkers)
tope15markers <- read.delim("E15_top_20_markers_per_allcluster_1154cells.txt", col.names = colnames)
tope15markers <- as.data.frame(tope15markers$gene) %>% unique 
E15.mn.avg.top20 <- merge(tope15markers, E15.mn.avg.sub, by.x = "tope15markers$gene", by.y = "gene", sort = F)
d <- E15.mn.avg.top20[,2:ncol(E15.mn.avg.top20)]
rnames <- E15.mn.avg.top20[,1]
mat_data<- data.matrix(d)
cc_cor_e15 <- cor(mat_data, method = "pearson") 
pheatmap(cc_cor_e15, color = colorpal, display_numbers = T, row.names = rnames)
colorpal = colorRampPalette(c("gray97", "deepskyblue4"))(100)
write.table(cc_cor_e15, file = "E15correlations_1154cells_top20markers_allclusters_exp.txt", sep = "\t", row.names = T)

