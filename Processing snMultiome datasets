pca_dist_all <- as.data.frame(rbind(pca_dist_E15_long, pca_dist_P3_long, pca_dist_P7_long, pca_dist_P13_long, pca_dist_P21_long, pca_dist_P56_long)) # %>% rename("age" = "V1", "corr" = "z")
pca_dist_all$age <- factor(pca_dist_all$age, levels = c("E15", "P3", "P7", "P13", "P21", "P56"))
p <- ggplot(pca_dist_all, aes(x=age, y=corr)) +
  geom_violin(trim = T, fill = "lightblue", alpha = 0.5) +
  geom_boxplot(width = 0.1, fill = "white", alpha = 0.5) +
  geom_jitter(shape = 16, position = position_jitter(0.2), alpha = 0.6) +
  theme_minimal() +
  labs(title = "Correlation MN with variable features",
       x = "Age",
       y = "Pair-wise correlations between clusters")
print(p)

anova_result <- pca_dist_all %>%
  anova_test(corr ~ age)

# Print ANOVA result
print(anova_result)

# Pairwise comparisons (if ANOVA is significant)
pairwise_results <-pca_dist_all %>%
  pairwise_t_test(corr ~ age, p.adjust.method = "bonferroni")
print(pairwise_results)
