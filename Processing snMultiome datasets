#################Processing of E15.5 multiome data. Identifying different cell types in the data, as in Figure 1d and Supplementary Figure 1. This can be repeated for all ages.

library(Seurat)
library(Signac)
library("EnsDb.Mmusculus.v79")
library("dplyr")
library("ggplot2")
library("BSgenome.Mmusculus.UCSC.mm10")


# the 10x hdf5 file contains both data types. 
inputdata.10x <- Read10X_h5("HT005_cellranger_arc_count_outs/filtered_feature_bc_matrix.h5")

# extract RNA and ATAC data
rna_counts <- inputdata.10x$`Gene Expression`
atac_counts <- inputdata.10x$Peaks

# Create Seurat object
E15.multi <- CreateSeuratObject(counts = rna_counts)
E15.multi[["percent.mt"]] <- PercentageFeatureSet(E15.multi, pattern = "^MT-")

# Now add in the ATAC-seq data
grange.counts <- StringToGRanges(rownames(atac_counts), sep = c(":", "-"))
grange.use <- seqnames(grange.counts) %in% standardChromosomes(grange.counts)
atac_counts <- atac_counts[as.vector(grange.use), ]
annotations <- GetGRangesFromEnsDb(ensdb = EnsDb.Mmusculus.v79)
seqlevelsStyle(annotations) <- 'UCSC'
genome(annotations) <- "mm10"

frag.file <- "HT005_cellranger_arc_count_outs/atac_fragments.tsv.gz"
chrom_assay <- CreateChromatinAssay(
  counts = atac_counts,
  sep = c(":", "-"),
  genome = 'mm10',
  fragments = frag.file,
  min.cells = 10,
  annotation = annotations
)
E15.multi[["ATAC"]] <- chrom_assay
VlnPlot(E15.multi.1k, features = c("nCount_ATAC", "nCount_RNA", "nFeature_RNA"), ncol = 3, log = TRUE, pt.size = 0.0) + NoLegend()

#test different subset parameters to ensure that clustering is not influenced by low quality cells
E15.multi.5k <- subset(
  x = E15.multi,
  subset = nCount_ATAC < 7e4 &
    nCount_ATAC > 5e3 &
    nCount_RNA < 25000 &
    nCount_RNA > 5000 &
    percent.mt < 20)


VlnPlot(E15.multi.5k, features = c("nCount_ATAC", "nCount_RNA", "nFeature_RNA"), ncol = 3, log = TRUE, pt.size = 0.0) + NoLegend()


# RNA analysis
DefaultAssay(E15.multi.5k) <- "RNA"
E15.multi.5k <- SCTransform(E15.multi.5k, verbose = FALSE) %>% RunPCA() %>% RunUMAP(dims = 1:50, reduction.name = 'umap.rna', reduction.key = 'rnaUMAP_')

# ATAC analysis
# We exclude the first dimension as this is typically correlated with sequencing depth
DefaultAssay(E15.multi.5k) <- "ATAC"
E15.multi.5k <- RunTFIDF(E15.multi.5k)
E15.multi.5k <- FindTopFeatures(E15.multi.5k, min.cutoff = 'q0')
E15.multi.5k <- RunSVD(E15.multi.5k)
E15.multi.5k <- RunUMAP(E15.multi.5k, reduction = 'lsi', dims = 2:50, reduction.name = "umap.atac", reduction.key = "atacUMAP_")

#Multimodal analysis
E15.multi.5k <- FindMultiModalNeighbors(E15.multi.5k, reduction.list = list("pca", "lsi"), dims.list = list(1:50, 2:50))
E15.multi.5k <- RunUMAP(E15.multi.5k, nn.name = "weighted.nn", reduction.name = "wnn.umap", reduction.key = "wnnUMAP_")
E15.multi.5k <- FindClusters(E15.multi.5k, graph.name = "wsnn", algorithm = 3, verbose = FALSE)
E15.multi.5k$celltype <- Idents(E15.multi.5k)
p1 <- DimPlot(E15.multi.5k, reduction = "umap.rna", group.by = "celltype", label = TRUE, label.size = 2.5, repel = TRUE) + ggtitle("RNA")
p2 <- DimPlot(E15.multi.5k, reduction = "umap.atac", group.by = "celltype", label = TRUE, label.size = 2.5, repel = TRUE) + ggtitle("ATAC")
p3 <- DimPlot(E15.multi.5k, reduction = "wnn.umap", group.by = "celltype", label = TRUE, label.size = 2.5, repel = TRUE) + ggtitle("WNN")
p1 + p2 + p3 & NoLegend() & theme(plot.title = element_text(hjust = 0.5))

