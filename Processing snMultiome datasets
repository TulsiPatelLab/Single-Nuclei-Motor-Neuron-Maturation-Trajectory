##############Correlations based on PCA loading genes


process_age_mix_cv <- function(obj, age, n_pcs = 50,
                               resolution = 0.8, cv_cutoff = 0.75,
                               ) {
  
  
  Idents(obj) <- "seurat_clusters"
  
  # RNA normalization and cluster averages
  DefaultAssay(obj) <- "RNA"
  obj <- NormalizeData(obj, verbose = FALSE)
  
  avg <- AggregateExpression(
    obj,
    assays = "RNA",
    group.by = "seurat_clusters",
    slot = "data",
    verbose = FALSE
  )$RNA
  
  # PCA genes that show covariance >0.75 in clusters
  obj <- FindVariableFeatures(obj, verbose = FALSE)
  obj <- ScaleData(obj, features = VariableFeatures(obj), verbose = FALSE)
  
  obj <- RunPCA(
    obj,
    assay = "RNA",
    reduction.name = "pca.rna",
    reduction.key = "RNAPC_",
    npcs = n_pcs,
    verbose = FALSE
  )
  
  loadings <- Loadings(obj, "pca.rna")[, 1:n_pcs, drop = FALSE]
  
  n_genes_per_pc <- 100
  genes_pca <- unique(unlist(lapply(seq_len(n_pcs), function(pc) {
    names(sort(abs(loadings[, pc]), decreasing = TRUE))[1:n_genes_per_pc]
  })))
  
  #CV genes across clusters
  gene_mean <- rowMeans(avg)
  gene_sd <- apply(avg, 1, sd)
  gene_cv <- gene_sd / gene_mean
  
  genes_cv <- names(gene_cv)[is.finite(gene_cv) & gene_cv > cv_cutoff]
  
  # intersect + mean expression filter
  genes_use <- intersect(genes_pca, genes_cv)
  genes_use <- intersect(genes_use, rownames(avg))
  genes_use <- genes_use[gene_mean[genes_use] > 0.1]
  
  avg_sub <- avg[genes_use, , drop = FALSE]
  cor_mat <- cor(as.matrix(avg_sub), method = "pearson")
  
  idx <- which(lower.tri(cor_mat), arr.ind = TRUE)
  cor_long <- tibble(
    age = age,
    cluster1 = rownames(cor_mat)[idx[, 1]],
    cluster2 = colnames(cor_mat)[idx[, 2]],
    corr = cor_mat[idx]
  )
  
  list(
    obj = obj,
    dimplot = dimplot,
    genes_use = genes_use,
    cor_mat = cor_mat,
    cor_long = cor_long
  )
}

