#Integration of snMultiome and snRNAseq

#E15_merge

E15.multi.5k.mn@meta.data[["orig.ident"]] <- "E15-10x"
E15.rna.mn@meta.data[["orig.ident"]] <- "E15-pip"

E15_merge <- merge(x = E15.multi.5k.mn, y = E15.rna.mn)

DefaultAssay(E15_merge) <- 'RNA'
E15_merge <- NormalizeData(E15_merge, assay = "RNA")
E15_merge <- FindVariableFeatures(E15_merge)
E15_merge <- ScaleData(E15_merge)
E15_merge <- RunPCA(E15_merge)
E15_merge <- IntegrateLayers(object = E15_merge, method = CCAIntegration, orig.reduction = "pca", new.reduction = "integrated.cca",
                             verbose = FALSE)

# now that integration is complete, rejoin layers
E15_merge@assays$RNA <- JoinLayers(E15_merge@assays$RNA)
E15_merge <- FindNeighbors(E15_merge, reduction = "integrated.cca", dims = 1:50)
E15_merge <- FindClusters(E15_merge, resolution = 0.5)
E15_merge <- RunUMAP(E15_merge, dims = 1:50, reduction = "integrated.cca", return.model=TRUE)
p1 <- DimPlot(E15_merge, reduction = "umap", label = T, group.by = "orig.ident")
p2 <- DimPlot(E15_merge, reduction = "umap", label = T, group.by = "seurat_clusters")
p1 | p2

table(E15_merge$orig.ident, E15_merge$seurat_clusters)

