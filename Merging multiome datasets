# Get a list of motif position frequency matrices from the JASPAR database
pfm <- getMatrixSet(
  x = JASPAR2020,
  opts = list(collection = "CORE", tax_group = 'vertebrates', all_versions = FALSE)
)

# add motif information
mn.allages <- AddMotifs(
  object = mn.allages,
  genome = BSgenome.Mmusculus.UCSC.mm10,
  pfm = pfm
)

#identify motifs enriched in alpha, gamma, and type3 peaks
mature.a.motifs <- FindMotifs(
  object = mn.allages,
  features = maturealphapeak.p$peak
)

mature.b.motifs <- FindMotifs(
  object = mn.allages,
  features = maturetype3peak.p$peak
)

mature.g.motifs <- FindMotifs(
  object = mn.allages,
