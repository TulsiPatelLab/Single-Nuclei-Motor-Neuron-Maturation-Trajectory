library(dplyr)
library(tidyr)
library(ggplot2)
library(patchwork)
library(scales)


palette_func <- colorRampPalette(c("#b075eb","indianred1", "darkgreen","#5bfee4","#d4ba6a", "darkblue"))

age_order <- c("e15 mns", "p3 mns", "p7 mns", "p13 mns", "p21 mns", "p56 mns")

make_100pct_barplot <- function(tab, plot_title = "", age_order = NULL) {
       
         long <- tab %>%
               rename(cluster = Var1) %>%
               pivot_longer(
                     cols = -cluster,
                     names_to = "age",
                     values_to = "n"
                 ) %>%
              mutate(
                     cluster = factor(cluster),
                     age = factor(age, levels = if (is.null(age_order)) unique(age) else age_order)
                 )
        
           n_clusters <- nlevels(long$cluster)
           cluster_cols <- palette_func(n_clusters)
          
             ggplot(long, aes(x = age, y = n, fill = cluster)) + 
                 geom_col(position = "fill") +
                 scale_fill_manual(values = cluster_cols) +
                 labs(
                       title = plot_title,
                       x = NULL,
                       y = "Proportion of cells"
                  ) +
               theme_classic()
      }

