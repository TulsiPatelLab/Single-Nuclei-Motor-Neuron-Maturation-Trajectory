#Label transfer analyses. 

#processing data from Alkaslasi et al.

expression_mtx <- ReadMtx(mtx = "~/GSE167597_RAW/Cervical_MF/matrix.mtx.gz", features = "~/GSE167597_RAW/Cervical_MF/features.tsv.gz", cells = "~/GSE167597_RAW/Cervical_MF/barcodes.tsv.gz")
cervical <- CreateSeuratObject(expression_mtx, min.features = 100) 
cervical[["percent.mt"]] <- PercentageFeatureSet(cervical, pattern = "^MT-")
# Visualize QC metrics as a violin plot
VlnPlot(cervical, features = c("nFeature_RNA", "nCount_RNA", "percent.mt"), ncol = 3)
cervical <- subset(cervical, subset = nFeature_RNA > 500 & nFeature_RNA < 4000 & percent.mt < 5)


expression_mtx <- ReadMtx(mtx = "~/GSE167597_RAW/Lumbar_MF/matrix.mtx.gz", features = "~/GSE167597_RAW/Lumbar_MF/features.tsv.gz", cells = "~/GSE167597_RAW/Lumbar_MF/barcodes.tsv.gz")
lumbar <- CreateSeuratObject(expression_mtx, min.features = 100) 
lumbar[["percent.mt"]] <- PercentageFeatureSet(lumbar, pattern = "^MT-")
# Visualize QC metrics as a violin plot
VlnPlot(lumbar, features = c("nFeature_RNA", "nCount_RNA", "percent.mt"), ncol = 3)
lumbar <- subset(lumbar, subset = nFeature_RNA > 500 & nFeature_RNA < 4000 & percent.mt < 5)


cervical@meta.data[["orig.ident"]] <- "cervical"
lumbar@meta.data[["orig.ident"]] <- "lumbar"


p56.c <- merge(cervical, lumbar, add.cell.ids = c("cervical", "lumbar"), project = "AlkaslasiP56")

p56.c <- NormalizeData(p56.c)
p56.c <- FindVariableFeatures(p56.c)
p56.c <- ScaleData(p56.c)
p56.c <- RunPCA(p56.c)
p56.c <- IntegrateLayers(object = p56.c, method = CCAIntegration, orig.reduction = "pca", new.reduction = "integrated.cca",
                              verbose = FALSE)

# now that integration is complete, rejoin layers
p56.c@assays[["RNA"]] <- JoinLayers(p56.c@assays[["RNA"]])

p56.c <- FindNeighbors(p56.c, reduction = "integrated.cca", dims = 1:30)
p56.c <- FindClusters(p56.c, resolution = 0.7)
p56.c <- RunUMAP(p56.c, dims = 1:30, reduction = "integrated.cca")
DimPlot(p56.c, label = T, label.size = 3)

features <- c("Pitx2", "Chat", "Slc5a7", "Arhgap36")
features <- c("Nos1", "Foxp1", "Zeb2", "Cpne4", "Fbn2", "Fign")
features <- c("Pitx2", "Tns1", "Ret", "Gfra1", "Bcl6")
features <- c("Zeb2", "Fbn2")
features <- c("Chat", "Gad1", "Slc17a6", "Tns1", "Zeb2", "Fbn2")
features <- c("Zeb2", "Fign", "Tns1", "Ret", "Bcl6")
FeaturePlot(p56.c, features = features)
VlnPlot(p56.c, features = features, group.by = "seurat_clusters")

#assigning cell IDs based on expression, subsetting SMNs and PGMNs (or pgmns)
p56.c.mn <- subset(p56.c, idents = c(2, 7, 11))
p56.c.mn <- SCTransform(p56.c.mn, vst.flavor = "v2", verbose = FALSE) %>%
  RunPCA(npcs = 50, verbose = FALSE) %>%
  RunUMAP(reduction = "pca", dims = 1:50, verbose = FALSE, return.model = T) %>%
  FindNeighbors(reduction = "pca", dims = 1:50, verbose = FALSE) %>%
  FindClusters(resolution = 0.7, verbose = FALSE)
DimPlot(p56.c.mn)
FeaturePlot(p56.c.mn, features = c("Klhl1", "Rora", "Aox1", "Gpr149"))

p56.c.pgmn <- subset(p56.c, idents = c(12, 13, 14, 17, 19, 21))
p56.c.pgmn <- SCTransform(p56.c.pgmn, vst.flavor = "v2", verbose = FALSE) %>%
  RunPCA(npcs = 50, verbose = FALSE) %>%
  RunUMAP(reduction = "pca", dims = 1:50, verbose = FALSE, return.model = T) %>%
  FindNeighbors(reduction = "pca", dims = 1:50, verbose = FALSE) %>%
  FindClusters(resolution = 0.7, verbose = FALSE)
DimPlot(p56.c.pgmn)
FeaturePlot(p56.c.mn, features = c("Creb5", "Rora", "Aox1", "Gpr149"))


